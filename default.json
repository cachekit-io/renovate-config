{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "group:allNonMajor",
    "helpers:pinGitHubActionDigests",
    ":semanticCommits",
    ":semanticCommitTypeAll(chore)"
  ],
  "timezone": "Australia/Sydney",
  "schedule": ["before 6am"],
  "labels": ["dependencies"],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 4,
  "prCreation": "not-pending",
  "minimumReleaseAge": "5 days",
  "platformAutomerge": true,
  "platformCommit": "enabled",
  "dependencyDashboard": true,
  "osvVulnerabilityAlerts": true,

  "enabledManagers": [
    "cargo",
    "github-actions",
    "npm",
    "pep621",
    "pip_requirements",
    "dockerfile",
    "docker-compose"
  ],

  "vulnerabilityAlerts": {
    "enabled": true,
    "schedule": ["at any time"],
    "minimumReleaseAge": "0 days",
    "labels": ["dependencies", "security"],
    "prPriority": 10,
    "automerge": false
  },

  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 6am on Monday"],
    "automerge": false
  },

  "packageRules": [
    {
      "description": "First-party cachekit-io packages propagate as fast as possible. They MUST have their own groupName: otherwise group:allNonMajor folds them into renovate/all-minor-patch, and that group follows the global (daily) schedule, silently overriding the at-any-time setting below (a grouped dep cannot keep its own schedule). With a dedicated group + no release-age quarantine (minimumReleaseAge defends against third-party supply-chain attacks, pointless for what we publish) + no schedule gate, an internal release (e.g. a cachekit-core patch) opens a dependent PR on the next hourly Renovate run. update-lockfile keeps the existing ^range and just bumps Cargo.lock. Major-version manual review still applies.",
      "matchPackageNames": ["cachekit{/,}**", "@cachekit-io/**"],
      "groupName": "first-party cachekit",
      "minimumReleaseAge": "0 days",
      "schedule": ["at any time"],
      "rangeStrategy": "update-lockfile"
    },
    {
      "description": "Auto-merge minor/patch dev dependencies after CI (age-gated by global minimumReleaseAge)",
      "matchDepTypes": ["devDependencies", "dev", "dev-dependencies"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "GitHub Actions: grouped manual review (CI infra blast radius)",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "github-actions",
      "automerge": false
    },
    {
      "description": "Group Rust dev dependencies",
      "matchManagers": ["cargo"],
      "matchDepTypes": ["dev-dependencies"],
      "groupName": "rust-dev-deps",
      "automerge": true
    },
    {
      "description": "Group Python test/lint tools",
      "matchManagers": ["pip_requirements", "pep621"],
      "matchPackageNames": ["pytest{/,}**", "ruff{/,}**", "basedpyright", "hypothesis", "faker"],
      "groupName": "python-dev-deps",
      "automerge": true
    },
    {
      "description": "Major version bumps always need manual review",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["dependencies", "major"]
    }
  ],

  "customManagers": [
    {
      "description": "Track ARG RUNNER_VERSION in runner Dockerfile against GitHub Releases",
      "customType": "regex",
      "fileMatch": ["(^|/)Dockerfile$"],
      "matchStrings": [
        "ARG\\s+RUNNER_VERSION=(?<currentValue>\\S+)\\s*\\n\\s*FROM\\s+ghcr\\.io/actions/actions-runner"
      ],
      "depNameTemplate": "actions/runner",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    }
  ],

  "docker": {
    "pinDigests": true
  }
}
